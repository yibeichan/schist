    },
    "fallback": "agent-owner",
    "hubIdentity": "gitolite-user",
    "mcpIdentity": "gitolite-user"
  },
  {
    "name": "empty_env_values_fall_through",
    "env": {
      "SCHIST_IDENTITY": "",
      "GL_USER": ""
    },
    "fallback": "agent-owner",
    "hubIdentity": null,
    "mcpIdentity": "agent-owner"
  }
