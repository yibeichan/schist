    },
    {
      "name": "zero-width space U+200B is NOT a separator",
      "line": "-\u200bextends: note-b",
      "expected": null
    },
    {
      "name": "no leading dash",
      "line": "extends: note-b",
      "expected": null
    },
    {
      "name": "missing target",
      "line": "- extends:",
      "expected": null
    },
    {
      "name": "no colon",
      "line": "- extends note-b",
      "expected": null
    },
    {
      "name": "single-token bracket target still matches (parsers skip it AFTER the regex)",
      "line": "- see: [Moltbook]",
      "expected": {
        "type": "see",
        "target": "[Moltbook]",
        "context": null
      }
    },
    {
      "name": "multi-token bracket reference does not match",
      "line": "- ref: [Moltbook, Jan 2026]",
      "expected": null
    },
    {
      "name": "trailing space defeats the anchored match",
      "line": "- extends: note-b ",
      "expected": null
    },
    {
      "name": "unknown type still matches at the regex level (vocabulary is checked elsewhere)",
      "line": "- bogus-type: x",
      "expected": {
        "type": "bogus-type",
        "target": "x",
        "context": null
      }
    },
    {
      "name": "empty quoted context collapses to null via the or-chain",
      "line": "- extends: note-b \"\"",
      "expected": {
        "type": "extends",
        "target": "note-b",
        "context": null
      }
    }
